DATABASE_URL="postgresql://USER@localhost:5432/smartvet_performance"
JWT_SECRET="change-me-in-production"
PORT=4000

# ── Email reminders, calendar invites & account verification ──────────────
# Leave SMTP_HOST unset to disable email sending — invites/reminders/
# verification links will just be logged to the console instead.
#
# For Zoho Mail: SMTP_HOST=smtp.zoho.com, SMTP_PORT=465, SMTP_USER is your
# full Zoho mailbox address, SMTP_PASS is an app-specific password generated
# at https://accounts.zoho.com/home#security/apppasswords (not your normal
# login password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Smartvet Team Leadership System <noreply@smartvet.africa>"

# Used to build links back into the app from emails (verification, reminders).
FRONTEND_URL="http://localhost:5174"

# ── Web push notifications ─────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:noreply@smartvet.africa"
